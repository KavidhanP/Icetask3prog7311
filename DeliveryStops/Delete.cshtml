@model LogiTech.Models.DeliveryStop
@{
    ViewData["Title"] = "Delete Stop";
    ViewData["ActivePage"] = "Route";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <h2>Delete Delivery Stop</h2>
    <p>This action cannot be undone</p>
</div>

<div style="max-width:500px;">
    <div class="card">
        <div style="background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.2);
                    border-radius:var(--radius);padding:16px;margin-bottom:20px;">
            <div style="color:var(--red);font-weight:600;margin-bottom:8px;">
                ⚠️ Are you sure you want to delete this stop?
            </div>
            <div style="font-size:0.85rem;color:var(--muted);">
                <strong>@Model.CustomerName</strong> — @Model.Address
            </div>
            <div style="font-size:0.82rem;color:var(--muted);margin-top:4px;">
                Priority: @Model.Priority |
                Tracking: @Model.TrackingNumber
            </div>
        </div>

        <form method="post" asp-action="Delete">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div style="display:flex;gap:12px;">
                <button type="submit" class="btn btn-danger" style="flex:1;">
                    Yes, Delete
                </button>
                <a class="btn btn-outline" asp-action="Index"
                   style="flex:1;text-align:center;">Cancel</a>
            </div>
        </form>
    </div>
</div>